# Internal Interface (Transit from Local)
ip addr add 172.16.0.1/30 dev eth0
# Public External Interface
ip addr add 203.0.113.2/30 dev eth1

# Enable Routing and NAT (Masquerade)
sysctl -w net.ipv4.ip_forward=1
iptables -t nat -A POSTROUTING -o eth1 -j MASQUERADE

# Static Route back to the Local LAN
ip route add 192.168.1.0/24 via 172.16.0.2
# Default route to the ISP/Internet
ip route add default via 203.0.113.1