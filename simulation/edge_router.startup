# Interfaces
ip addr add 172.16.0.1/29 dev eth0   # Facing Edge Switch
ip addr add 203.0.113.2/30 dev eth1  # Public IP facing Internet
ip route add default via 203.0.113.1

# Routing & NAT
sysctl -w net.ipv4.ip_forward=1
iptables -t nat -A POSTROUTING -o eth1 -j MASQUERADE

# Route back to local network (since no NAT is inside)
ip route add 192.168.1.0/24 via 172.16.0.2
ip route add 192.168.2.0/24 via 172.16.0.3
ip route add 192.168.3.0/24 via 172.16.0.4

#--------------------------
# Prevent LAN cross talk
#--------------------------

iptables -A FORWARD -s 192.168.1.0/24 -d 192.168.2.0/24 -j DROP
iptables -A FORWARD -s 192.168.1.0/24 -d 192.168.3.0/24 -j DROP
iptables -A FORWARD -s 192.168.2.0/24 -d 192.168.1.0/24 -j DROP
iptables -A FORWARD -s 192.168.2.0/24 -d 192.168.3.0/24 -j DROP
iptables -A FORWARD -s 192.168.3.0/24 -d 192.168.1.0/24 -j DROP
iptables -A FORWARD -s 192.168.3.0/24 -d 192.168.2.0/24 -j DROP

#--------------------------
# Allow internet access
#--------------------------

iptables -A FORWARD -i eth0 -o eth1 -j ACCEPT

#--------------------------
# Port Scanning Prevention
#--------------------------

# Set default policies to DROP for the FORWARD chain
iptables -P FORWARD DROP

# Allow established/related traffic (so your internal PCs can get replies)
iptables -A FORWARD -m state --state ESTABLISHED,RELATED -j ACCEPT

# Only allow specific ports (e.g., HTTP/HTTPS) to pass through
iptables -A FORWARD -p tcp --dport 80 -j ACCEPT
iptables -A FORWARD -p tcp --dport 443 -j ACCEPT

# ------------------
# Drop Stealth scan
#-------------------

# Drop NULL scans (packets with no flags)
iptables -A FORWARD -p tcp --tcp-flags ALL NONE -j DROP

# Drop Xmas scans (packets with all flags set)
iptables -A FORWARD -p tcp --tcp-flags ALL ALL -j DROP

# Drop FIN scans
iptables -A FORWARD -p tcp --tcp-flags ALL FIN -j DROP
